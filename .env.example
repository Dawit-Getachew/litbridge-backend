# ===========================================

# LitBridge Backend — Environment Variables
# Copy this to .env and fill in real values
# ===========================================

# --- Core ---
APP_NAME=LitBridge
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
# In Coolify: use the internal service hostname, e.g. postgres:5432
POSTGRES_USER=litbridge
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=litbridge
DATABASE_URL=postgresql+asyncpg://litbridge:CHANGE_ME@postgres:5432/litbridge

# --- Cache (Redis) ---
# In Coolify: use the internal service hostname, e.g. redis:6379
REDIS_URL=redis://redis:6379/0

# --- PubMed / NCBI ---
NCBI_API_KEY=your_ncbi_api_key_here
CONTACT_EMAIL=your@email.com

# --- LLM Provider ---
# Set to "openai" or "openrouter"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (alternative — set LLM_PROVIDER=openrouter to use)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Semantic Scholar (optional, improves TLDR quality) ---
SEMANTIC_SCHOLAR_API_KEY=

# --- CORS ---
# JSON array of allowed origins for the frontend
CORS_ORIGINS=["*"]

# --- Security ---
SECRET_KEY=generate-a-random-64-char-string-here

# --- Email (SendGrid) ---
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=info@scienthesis.ai
SENDGRID_FROM_NAME="LitBridge by Scienthesis"
ADMIN_EMAIL=info@scienthesis.ai

# --- Auth (JWT / OTP) ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=5

# ===========================================
# --- Ranking (Free-Text Search v3) ---
# ===========================================
# Every cached search result key embeds this version; bump it whenever you
# change a ranking default below so callers don't serve stale orderings.
# RANKING_VERSION=v3

# Per-source RRF weights. PubMed gets a 2.5x boost on FREE queries because
# the client's benchmark rated it 7/10 (our previous tie was 4/10). OpenAlex
# is down-weighted because its biomedical recall is noisier than Europe PMC's.
# ClinicalTrials.gov is zeroed for FREE queries (protocols rarely match the
# information-retrieval intent of a free-text biomedical search); non-FREE
# queries that explicitly include CT.gov still use weight 1.0.
# RANKING_PUBMED_WEIGHT=2.5
# RANKING_EUROPEPMC_WEIGHT=1.0
# RANKING_OPENALEX_WEIGHT=0.5
# RANKING_CTGOV_WEIGHT=0.0

# Lexical and recency boosts. Multiplicative on top of the RRF score.
# RANKING_TITLE_BOOST=0.30         # title term-coverage lift (0.0 = off)
# RANKING_ABSTRACT_BOOST=0.15      # abstract term-coverage lift (0.0 = off)
# RANKING_RECENCY_BOOST=0.10       # decays linearly over 5 years (0.0 = off)
# RANKING_CITATION_BOOST=0.25      # log1p(citations)-based prestige signal
# RANKING_CITATION_CAP=0.40        # hard cap so 10k-cite seminal papers don't swamp fresh niche hits

# RRF denominator constant. Industry default is 60; raise to soften rank dominance.
# RANKING_RRF_K=60

# MMR diversification for top-K clusters. Lambda=1.0 disables MMR entirely
# (pure relevance). Lambda<1.0 blends in Jaccard-title diversity.
# RANKING_MMR_LAMBDA=1.0
# RANKING_MMR_K=20

# Local BM25 reranker over title+abstract (bm25s, pure-Python). Weight is
# the share of the blended score the BM25 signal contributes vs RRF.
# Set to 0.0 to disable entirely.
# RANKING_BM25_WEIGHT=0.35
# RANKING_BM25_TOP_K=200

# LLM-based query rewriter. Default ON, but gated at runtime to exactly
# QueryType.FREE + SearchMode.QUICK — deep modes have their own query
# synthesis pipeline and do not need a rewrite.
# RANKING_LLM_REWRITE=true
# RANKING_LLM_REWRITE_TIMEOUT_SECONDS=6
# RANKING_LLM_REWRITE_CACHE_TTL_SECONDS=86400
# RANKING_QUERY2DOC_ENABLED=true   # Query2doc pseudo-abstract expansion

# MedCPT cross-encoder reranker (NCBI's BERT trained on PubMed click logs).
# DEFAULT OFF — you must export weights first and opt in explicitly.
# Backend choices:
#   onnx         -> in-process ONNX Runtime (recommended for Coolify)
#   sidecar      -> HTTP POST to http://medcpt:8000/rerank sidecar
#   hf_endpoints -> dedicated Hugging Face Inference Endpoint
#   hf_api       -> pay-per-call Hugging Face serverless API
# RANKING_MEDCPT=false
# RANKING_MEDCPT_BACKEND=onnx
# RANKING_MEDCPT_TOP_K=100
# RANKING_MEDCPT_MODEL_PATH=./models/medcpt-cross-onnx-qint8
# HF_MEDCPT_ENDPOINT_URL=
# HF_API_TOKEN=