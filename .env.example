# ===========================================

# LitBridge Backend — Environment Variables
# Copy this to .env and fill in real values
# ===========================================

# --- Core ---
APP_NAME=LitBridge
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
# In Coolify: use the internal service hostname, e.g. postgres:5432
POSTGRES_USER=litbridge
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=litbridge
DATABASE_URL=postgresql+asyncpg://litbridge:CHANGE_ME@postgres:5432/litbridge

# --- Cache (Redis) ---
# In Coolify: use the internal service hostname, e.g. redis:6379
REDIS_URL=redis://redis:6379/0

# --- PubMed / NCBI ---
NCBI_API_KEY=your_ncbi_api_key_here
CONTACT_EMAIL=your@email.com

# --- LLM Provider ---
# Set to "openai" or "openrouter"
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (alternative — set LLM_PROVIDER=openrouter to use)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Semantic Scholar (optional, improves TLDR quality) ---
SEMANTIC_SCHOLAR_API_KEY=

# --- CORS ---
# JSON array of allowed origins for the frontend
CORS_ORIGINS=["*"]

# --- Security ---
SECRET_KEY=generate-a-random-64-char-string-here

# --- Email (SendGrid) ---
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=info@scienthesis.ai
SENDGRID_FROM_NAME="LitBridge by Scienthesis"
ADMIN_EMAIL=info@scienthesis.ai

# --- Auth (JWT / OTP) ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=5