# ===========================================
# LitBridge Backend Environment Variables
# Copy this to .env and fill in your real values
# ===========================================

# --- Core ---
APP_NAME=LitBridge
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL via Docker) ---
POSTGRES_USER=litbridge
POSTGRES_PASSWORD=litbridge_dev_2026
POSTGRES_DB=litbridge
DATABASE_URL=postgresql+asyncpg://litbridge:litbridge_dev_2026@localhost:5432/litbridge

# --- Cache (Redis via Docker) ---
REDIS_URL=redis://localhost:6379/0

# --- PubMed / NCBI (REQUIRED) ---
# Get your API key: https://www.ncbi.nlm.nih.gov/account/ → Settings → API Key
NCBI_API_KEY=your_ncbi_api_key_here
CONTACT_EMAIL=your@email.com

# --- LLM Provider ---
# Set LLM_PROVIDER to "openai" or "openrouter"
# Only fill in the key for the provider you're using
LLM_PROVIDER=openai

# OpenAI Direct
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter (OpenAI-compatible, 200+ models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- Semantic Scholar (OPTIONAL - higher rate limits) ---
# Get API key: https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# --- Free APIs (no keys needed) ---
# OpenAlex: uses CONTACT_EMAIL for polite pool
# ClinicalTrials.gov: no auth
# Europe PMC: no auth
# Unpaywall: uses CONTACT_EMAIL
# Crossref: uses CONTACT_EMAIL for polite pool
# OpenCitations: no auth

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-key
